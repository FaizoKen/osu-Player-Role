# =========================================================================
# osu!-Player-Role plugin — environment template.
# Copy to `.env` and fill in. Generators for the random bits:
#   openssl rand -base64 24    # POSTGRES_PASSWORD
#   openssl rand -base64 48    # SESSION_SECRET
#   openssl rand -hex 32       # INTERNAL_API_KEY
# =========================================================================

# PostgreSQL password — used by the `db` service in compose.yml AND
# interpolated into DATABASE_URL. Keep both halves consistent.
POSTGRES_PASSWORD=

# `${POSTGRES_PASSWORD}` is interpolated by compose; if you run the binary
# outside docker, replace the placeholder with the literal password.
DATABASE_URL=postgres://opr:${POSTGRES_PASSWORD}@db:5432/osu_player_role

# HMAC key for `rl_session` cookies + the iframe-session token. MUST be the
# same value the Auth Gateway uses (cookies are shared across all plugins on
# the same domain). Generate per environment.
SESSION_SECRET=

# Public-facing base URL of this plugin (no trailing slash). MUST be HTTPS
# in prod and MUST include the plugin path prefix.
BASE_URL=https://your-domain.com/osu-player-role

LISTEN_ADDR=0.0.0.0:8095

# Auth Gateway URL. Defaults to deriving the origin from BASE_URL when
# unset; set explicitly in local dev.
# AUTH_GATEWAY_URL=http://localhost:8090

# Shared secret with the Auth Gateway. The `X-Internal-Key` header on every
# `/auth/internal/*` call must match this value.
INTERNAL_API_KEY=

# Override per environment. No trailing slash.
# ROLELOGIC_API_URL=https://api-rolelogic.faizo.net

# Origin allowed to embed this plugin's role-config page (the RoleLogic
# dashboard's origin). Defaults to https://rolelogic.faizo.net when unset.
# RL_DASHBOARD_ORIGIN=https://rolelogic.faizo.net

# --- osu! OAuth credentials ---------------------------------------------
#
# Register an OAuth Application at https://osu.ppy.sh/home/account/edit
# (scroll to "OAuth"). The "Application Callback URL" you register MUST be
#   {BASE_URL}/oauth/osu/callback
# exactly. Scopes used: `identify` (read public profile + statistics).
# OSU_CLIENT_ID=
# OSU_CLIENT_SECRET=

# --- Scaling knobs -------------------------------------------------------

# Number of job-polling worker tasks. Each claims a batch via
# `FOR UPDATE SKIP LOCKED`, scales linearly until DB-pool saturation.
# WORKER_CONCURRENCY=4

# Number of concurrent osu! API refresh fetches. Keep low — osu!'s public
# rate-limit guideline is ~60 req/min per application.
# REFRESH_CONCURRENCY=2

# DB pool sizing. Budget (replicas * DB_MAX_CONNECTIONS) ≤ pgBouncer pool.
# DB_MAX_CONNECTIONS=16
# DB_MIN_CONNECTIONS=2
# DB_ACQUIRE_TIMEOUT_SECS=5
# DB_IDLE_TIMEOUT_SECS=600

# Default keeps app logs at INFO and `tower_http` at WARN.
RUST_LOG=osu_player_role=info,tower_http=warn
